# ============================================================================
# REQUIRED
# ============================================================================

# Supabase — Postgres + Auth + pgvector
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Cron job authorization (used by /api/cron/* endpoints)
CRON_SECRET=your-cron-secret

# Transactional email
RESEND_API_KEY=re_...

# ============================================================================
# OPTIONAL — Infrastructure
# ============================================================================

# Upstash Redis — falls back to in-memory rate limiting if not set
# Get from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase connection pooler URL (for direct DB connections)
# Enable PgBouncer in Supabase dashboard → Settings → Database
SUPABASE_DB_POOLER_URL=

# ============================================================================
# OPTIONAL — Observability
# ============================================================================

# Sentry error tracking
NEXT_PUBLIC_SENTRY_DSN=

# GitHub API token (higher rate limits for tool-intelligence cron)
GITHUB_TOKEN=ghp_...

# ============================================================================
# OPTIONAL — Security
# ============================================================================

# Comma-separated list of allowed CORS origins for /api/v1/*
# Same-origin always allowed. Leave empty for same-origin only.
CORS_ALLOWED_ORIGINS=

# ============================================================================
# OPTIONAL — Feature flags
# ============================================================================

# Emergency disable for the AI assistant endpoint (cost control)
# Set to "true" to return service_unavailable from /api/assistant
DISABLE_ASSISTANT=

# ============================================================================
# Local development
# ============================================================================

NEXT_PUBLIC_SITE_URL=http://localhost:3000
